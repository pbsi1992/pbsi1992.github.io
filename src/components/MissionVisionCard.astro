---
interface Props {
  title: string;
  icon: any;
}

const { title, icon: Icon } = Astro.props;
---

<div class="bg-site-card border border-site-border p-10 rounded-[40px] shadow-sm flex flex-col group hover:border-primary/20 transition-colors duration-500">
  <div class="flex items-center gap-5 mb-8">
    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:scale-110 transition-transform duration-500 shrink-0">
      <Icon size={28} />
    </div>
    <h2 class="text-[14px] font-black uppercase tracking-[0.2em] text-primary">{title}</h2>
  </div>
  
  <div class="flex-grow">
    <slot />
  </div>
</div>