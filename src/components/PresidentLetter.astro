---
import { Image } from 'astro:assets';
import presidentPhoto from '../assets/president-photo.jpg'; 
---

<div class="relative overflow-visible" id="president-section">
  <div 
    id="pres-photo-flying" 
    class="fixed pointer-events-none z-[40] overflow-hidden border-4 border-primary rounded-[24px] bg-site-bg shadow-xl hidden lg:block opacity-0 transition-opacity duration-300"
    style="will-change: transform; transform: translate3d(0,0,0); top: 0; left: 0;"
  >
     <Image src={presidentPhoto} alt="Rev. Joval C. Kisinamal" class="w-full h-full object-cover" />
  </div>

  <section class="py-6 md:py-24 bg-site-card/30">
    <div class="max-w-[1200px] mx-auto px-4 md:px-10 relative">
      
      <div class="bg-site-card border border-site-border rounded-[32px] md:rounded-[48px] p-6 md:p-20 shadow-2xl relative z-10">
        <div class="flex flex-col lg:flex-row gap-6 md:gap-16 items-start">
          
          <div class="lg:w-1/3 w-full lg:sticky lg:top-40 self-start">
            <div class="relative mb-2 lg:mb-8 h-auto lg:aspect-[4/5] w-full max-w-[280px] mx-auto lg:max-w-none">
              <div class="absolute -inset-4 bg-primary/10 rounded-[32px] blur-2xl lg:block hidden"></div>
              
              <div id="pres-photo-start" class="w-full h-full rounded-[24px] overflow-hidden border-4 border-primary lg:border-none">
                <Image src={presidentPhoto} alt="Rev. Joval C. Kisinamal" class="w-full h-full object-cover lg:opacity-0" />
              </div>
            </div>

            <div id="pres-sidebar-text" class="text-center lg:text-left">
              <h2 class="text-2xl font-bold text-site-text mb-0.5 text-pretty">Rev. Joval C. Kisinamal</h2>
              <p class="text-primary font-bold uppercase tracking-widest text-[10px] mb-6 lg:mb-6">President, PBSI</p>
              <p class="text-site-muted italic text-sm leading-relaxed border-l-2 border-primary/20 pl-4 hidden lg:block">
                "The future of the Church and society depends on leaders who are both biblically grounded and spiritually vibrant."
              </p>
            </div>
          </div>

          <div class="lg:w-2/3 w-full">
            <h3 class="text-primary font-bold tracking-widest uppercase text-[10px] md:text-sm mb-1 md:mb-2">From the President’s Desk</h3>
            <h4 class="text-3xl md:text-5xl font-extrabold text-site-text mb-6 md:mb-10 leading-tight tracking-tight">
                A Pastoral Challenge
            </h4>

            <div class="prose prose-base md:prose-lg dark:prose-invert max-w-none text-site-muted leading-relaxed space-y-6">
              <p class="text-site-text font-semibold text-lg md:text-xl">Beloved Brothers and Sisters in Christ,</p>
              <p>Warm greetings in the matchless name of our Lord and Savior Jesus Christ.</p>
              
              <p>
                The call to raise up godly leaders is as urgent today as it was in the days of the apostles. The Church and society alike are in great need of men and women who are deeply rooted in the Word of God, shaped in character, and equipped in practical ministry. As leaders entrusted with God’s flock and as influencers in our communities, we are given the sacred responsibility to prepare the next generation to stand firm in truth and to serve with excellence.
              </p>

              <p>
                Presbyterian Bible Seminary, Inc. (PBSI) exists for this very purpose. As an institution committed to the <strong>Reformed Biblical Doctrine and Traditions</strong>, our mission is to promote excellence in Spirituality, Character, Practical Ministry, and Academics. By God’s grace, we seek to nurture leaders who embody integrity, compassion, and courage—leaders who will faithfully shepherd God’s people and serve society with wisdom and humility.
              </p>

              <p>
                Today, I write to challenge you—pastors, elders, church officers, and community leaders—to prayerfully consider the prospect leaders among you. Look among your flock and community for those whom God may be calling into deeper training and equipping for His kingdom work. Encourage them, guide them, and bring them to an institution where their calling may be tested, refined, and strengthened for the glory of God.
              </p>

              <p>
                Let us not delay in this vital work. The future of the Church and society depends on leaders who are both biblically grounded and spiritually vibrant. I invite you to partner with us at PBSI in fulfilling this mandate of raising up servant-leaders who will stand on the truth of Scripture and live out the gospel faithfully.
              </p>

              <p>
                May the Lord grant us discernment, courage, and faithfulness as we together invest in the next generation of Christlike leaders.
              </p>

              <div class="pt-10 border-t border-site-border">
                <p class="text-site-text font-medium mb-1">In His Service,</p>
                <p class="text-3xl font-serif italic text-primary font-bold">Rev. Joval C. Kisinamal</p>
                <p class="text-xs font-bold text-site-muted mt-1">President, Presbyterian Bible Seminary, Inc</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 md:mt-12 bg-site-bg border-2 border-site-border p-6 md:p-10 rounded-[32px] md:rounded-[40px] shadow-xl relative z-30">
          <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-center">
              
              <div id="pres-photo-end" class="w-32 md:w-44 aspect-[4/5] rounded-2xl bg-site-card/50 border-2 border-dashed border-site-border shrink-0 overflow-hidden">
                <Image src={presidentPhoto} alt="Rev. Joval C. Kisinamal" class="w-full h-full object-cover lg:hidden" />
              </div>

              <div class="flex-1 text-center md:text-left">
                  <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-1">PBSI President</p>
                  <h5 class="text-3xl md:text-4xl font-serif italic text-site-text font-bold mb-2">Rev. Joval C. Kisinamal</h5>
                  <p class="text-[11px] font-medium text-site-muted mb-6">
                    Ph.D. in Visual Arts (Honoris Causa) • M.A. in Inter-Cultural Studies (Ongoing) • Units in M. Div. • B.Th. • TESOL
                  </p>

                  <div class="flex flex-col md:flex-row justify-between items-center md:items-end gap-4 border-t border-site-border pt-4">
                      <div class="text-[11px] font-bold text-site-text hidden md:block">
                          <p class="text-primary uppercase text-[9px] mb-1">Major Disciplines</p>
                          <p>Church History • Theology • Hermeneutics • Counseling</p>
                      </div>
                      <div class="flex flex-wrap gap-1 justify-center md:justify-end">
                          {['Missionary', 'Artist', 'Designer', 'Animator', 'Teacher'].map((r) => (
                              <span class="text-[8px] font-bold uppercase px-2 py-1 bg-primary/5 border border-primary/10 rounded text-primary">{r}</span>
                          ))}
                      </div>
                  </div>
              </div>
          </div>
      </div>
    </div>
  </section>
</div>

<script>
  const flyingPhoto = document.getElementById('pres-photo-flying');
  const startPos = document.getElementById('pres-photo-start');
  const endPos = document.getElementById('pres-photo-end');
  const sidebarText = document.getElementById('pres-sidebar-text');

  // TS FIX: Assigned proper type to handle the error in your screenshot
  let rAF: number | null = null;

  const updatePhoto = () => {
    if (!flyingPhoto || !startPos || !endPos || window.innerWidth < 1024) {
      if(flyingPhoto) flyingPhoto.style.display = 'none';
      return;
    }

    const sRect = startPos.getBoundingClientRect();
    const eRect = endPos.getBoundingClientRect();

    const triggerStart = window.innerHeight * 0.95; 
    const triggerEnd = window.innerHeight * 0.5;
    
    let flightProgress = (triggerStart - eRect.top) / (triggerStart - triggerEnd);
    flightProgress = Math.max(0, Math.min(1, flightProgress));

    const currentW = sRect.width + (eRect.width - sRect.width) * flightProgress;
    const currentH = sRect.height + (eRect.height - sRect.height) * flightProgress;
    const currentX = sRect.left + (eRect.left - sRect.left) * flightProgress;
    const currentY = sRect.top + (eRect.top - sRect.top) * flightProgress;

    flyingPhoto.style.width = `${currentW}px`;
    flyingPhoto.style.height = `${currentH}px`;
    flyingPhoto.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
    
    flyingPhoto.style.borderRadius = `${24 - (flightProgress * 8)}px`;
    flyingPhoto.style.borderWidth = `${4 - (flightProgress * 2)}px`;
    
    if(sidebarText) sidebarText.style.opacity = (1 - flightProgress * 3).toString();
    
    if (sRect.bottom < 0 && flightProgress === 0) {
        flyingPhoto.style.display = 'none';
    } else {
        flyingPhoto.style.display = 'block';
        flyingPhoto.classList.remove('opacity-0');
    }
  };

  const onScroll = () => {
    if (rAF !== null) {
        cancelAnimationFrame(rAF);
    }
    rAF = requestAnimationFrame(updatePhoto);
  };

  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', updatePhoto);
  updatePhoto();
</script>