---
---
<button
  id="theme-toggle"
  class="group relative p-2.5 rounded-xl border border-site-border bg-site-bg hover:border-primary/40 transition-all flex items-center justify-center shadow-sm overflow-hidden"
  aria-label="Toggle Theme"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="theme-icon transition-transform duration-700 ease-in-out group-hover:rotate-45"
  >
    <mask id="moon-mask">
      <rect x="0" y="0" width="100%" height="100%" fill="white" />
      <circle cx="24" cy="10" r="6" fill="black" class="mask-circle transition-all duration-700 ease-in-out" />
    </mask>

    <circle 
      cx="12" 
      cy="12" 
      r="5" 
      mask="url(#moon-mask)" 
      class="main-circle fill-primary stroke-primary transition-all duration-700 ease-in-out"
    />

    <g class="sun-rays stroke-primary transition-all duration-700 ease-in-out">
      <line x1="12" y1="1" x2="12" y2="3"></line>
      <line x1="12" y1="21" x2="12" y2="23"></line>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
      <line x1="1" y1="12" x2="3" y2="12"></line>
      <line x1="21" y1="12" x2="23" y2="12"></line>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
    </g>
  </svg>
</button>

<style>
  /* Base Light Mode (Sun) */
  .main-circle {
    fill: var(--brand-primary);
    stroke: var(--brand-primary);
  }

  /* Dark Mode Transformation */
  :global(.dark) .theme-icon {
    transform: rotate(40deg);
  }

  :global(.dark) .main-circle {
    fill: #FACC15; /* Golden Moon */
    stroke: #FACC15;
    r: 8; 
  }

  :global(.dark) .mask-circle {
    cx: 18;
    cy: 8;
  }

  :global(.dark) .sun-rays {
    opacity: 0;
    transform: scale(0.5);
  }
</style>

<script is:inline>
  /**
   * Toggles the 'dark' class on the root element 
   * and saves the preference to localStorage.
   */
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  };

  /**
   * Attaches the event listener. 
   * We wrap this in a function to support View Transitions.
   */
  const setupThemeToggle = () => {
    const toggleBtn = document.getElementById("theme-toggle");
    if (toggleBtn) {
      toggleBtn.addEventListener("click", handleToggleClick);
    }
  };

  // Initial load
  setupThemeToggle();

  // Listen for Astro's page swaps to re-initialize the button logic
  document.addEventListener('astro:after-swap', setupThemeToggle);
</script>