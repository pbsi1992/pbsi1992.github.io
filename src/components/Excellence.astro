---
const aims = [
  "Quality and holistic Christian educational and leadership services",
  "Trains men and women for the building-up of the church and transformation of society",
  "Serves as a catalyst for the expansion of God's kingdom on earth"
];
---

<section class="max-w-[1596px] mx-auto px-4 md:px-10 py-24">
  <div class="bg-site-card border border-site-border rounded-[32px] p-8 md:p-20 shadow-sm transition-colors duration-300">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="max-w-xl">
        <h2 class="text-4xl md:text-5xl font-extrabold text-site-text leading-tight tracking-tight">
          Aim of Excellence in <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-light">
            Spiritual, Character, Practical, and Academics
          </span>
        </h2>
        <div class="mt-6 w-20 h-1.5 bg-primary rounded-full"></div>
      </div>

      <div class="space-y-8">
        {aims.map((aim) => (
          <div class="group flex items-start gap-5">
            <div class="mt-1 flex-shrink-0 w-8 h-8 rounded-xl bg-primary/10 flex items-center justify-center transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <p class="text-site-muted text-lg md:text-xl leading-relaxed font-medium">
              {aim}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>