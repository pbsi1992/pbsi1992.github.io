<section class="relative w-full pt-48 pb-40 overflow-hidden -mt-[120px]">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[80%] h-[60%] bg-primary/15 dark:bg-primary/20 blur-[140px] rounded-full"></div>
    <div class="absolute bottom-[10%] left-[-5%] w-[50%] h-[50%] bg-primary-light/10 blur-[100px] rounded-full"></div>

    <div class="absolute inset-0 opacity-[0.06] dark:opacity-[0.03] [mask-image:linear-gradient(to_bottom,black,transparent)]" 
         style="background-image: url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9IiMwMDMzQTAiLz48L3N2Zz4=');">
    </div>
  </div>

  <div class="relative z-10 max-w-[1596px] mx-auto px-4 md:px-10 text-center">
    <div class="inline-flex items-center gap-2 bg-site-card/40 backdrop-blur-sm px-6 py-3 rounded-full border border-site-border mb-12 shadow-sm">
      <span class="relative flex h-3 w-3">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex rounded-full h-3 w-3 bg-primary"></span>
      </span>
      <h2 class="text-base md:text-lg font-bold tracking-tight text-primary">
        Equipping Christ-like Leaders
      </h2>
    </div>
    
    <h1 class="text-6xl md:text-8xl lg:text-9xl font-extrabold text-site-text leading-[0.95] mb-10 tracking-tighter">
      Presbyterian Bible <br class="hidden lg:block" /> 
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-primary-light">Seminary Inc.</span>
    </h1>
    
    <p class="text-site-muted max-w-3xl mx-auto text-xl md:text-2xl leading-relaxed mb-16 font-medium">
      Dedicated to providing biblical and theological education to prepare men and women for the ministry of the Word and global service.
    </p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-5">
      <a href="/admission" class="bg-primary text-white px-14 py-6 rounded-2xl font-bold text-xl transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-primary/40 active:scale-95">
        Pre-registration
      </a>
      <a href="/about" class="bg-site-card/60 backdrop-blur-sm text-site-text border-2 border-site-border px-14 py-6 rounded-2xl font-bold text-xl transition-all duration-300 hover:-translate-y-1 hover:bg-site-card hover:border-primary/20 active:scale-95">
        Learn More
      </a>
    </div>
  </div>
</section>