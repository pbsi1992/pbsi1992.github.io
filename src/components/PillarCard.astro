---
interface Props {
  index: number;
  title: string;
  icon: any; 
}

const { index, title, icon: Icon } = Astro.props;
const displayNumber = (index + 1).toString().padStart(2, '0');
---

<div class="bg-site-card border border-site-border p-10 rounded-[32px] hover:border-primary/20 transition-all duration-300 group flex flex-col items-center text-center h-full">
  <div class="flex flex-col items-center mb-6">
    <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-4 group-hover:scale-110 transition-transform duration-500">
      <Icon size={24} />
    </div>
    <div>
      <span class="text-[10px] font-black text-primary/40 uppercase block leading-none mb-2 tracking-[0.2em]">
        Pillar {displayNumber}
      </span>
      <h4 class="text-2xl font-extrabold text-site-text tracking-tight uppercase leading-none">{title}</h4>
    </div>
  </div>
  
  <div class="text-base text-site-muted leading-relaxed font-medium max-w-[280px]">
    <slot />
  </div>
</div>