---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { UserPlus, FileText, CheckCircle, ArrowRight, ChevronDown } from 'lucide-react';

const allPrograms = await getCollection('programs');

const steps = [
  { 
    icon: UserPlus, 
    title: "Apply", 
    desc: "Fill out the digital application form below." 
  },
  { 
    icon: FileText, 
    title: "Verify", 
    desc: "Our registrar will review your requirements." 
  },
  { 
    icon: CheckCircle, 
    title: "Enroll", 
    desc: "Receive your student ID and start your journey." 
  }
];
---

<Layout title="Admissions">
  <main class="bg-site-bg min-h-screen pt-12 pb-24 relative overflow-hidden">
    
    <div class="absolute top-[-5%] right-[-10%] w-[300px] md:w-[600px] h-[300px] md:h-[600px] bg-primary/10 rounded-full blur-[80px] md:blur-[120px] -z-10"></div>

    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      
      <div class="mb-12 md:mb-20">
        <p class="text-primary font-black tracking-[0.4em] text-[10px] md:text-xs mb-4 uppercase">Enrollment 2026-2027</p>
        <h1 class="text-5xl sm:text-7xl md:text-9xl font-black text-site-text tracking-tighter uppercase italic leading-none">
          Admissions<span class="text-primary text-outline">.</span>
        </h1>
      </div>

      <div class="flex flex-col lg:flex-row gap-10 items-stretch">
        
        <div class="flex flex-col gap-6 shrink-0 w-full lg:w-[360px]">
          <div class="p-6 md:p-8 bg-site-card/40 backdrop-blur-md border border-site-border rounded-[32px] shadow-sm">
            <h3 class="text-xl md:text-2xl font-black italic uppercase text-site-text mb-8 tracking-tight">The Process</h3>
            
            <div class="space-y-10 relative">
              <div class="absolute left-[23px] top-4 bottom-4 w-1 bg-primary/10 -z-10"></div>
              
              {steps.map((step) => (
                <div class="flex gap-6 items-start group">
                  <div class="bg-site-bg border border-site-border text-primary w-12 h-12 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-primary group-hover:text-white transition-all shadow-lg">
                    <step.icon size={20} />
                  </div>
                  <div class="min-w-0">
                    <h4 class="font-black text-site-text uppercase text-xs md:text-sm tracking-widest mb-1">{step.title}</h4>
                    <p class="text-[11px] md:text-xs font-bold text-site-muted leading-relaxed">{step.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="bg-primary text-white p-8 md:p-10 rounded-[32px] shadow-xl shadow-primary/20 flex-grow relative overflow-hidden">
            <div class="relative z-10">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] mb-4 opacity-70">Notice</p>
                <h4 class="text-2xl md:text-3xl font-black italic uppercase leading-tight mb-4 text-white">Limited Slots</h4>
                <p class="text-xs md:text-sm font-bold italic opacity-90 leading-relaxed uppercase text-white/90">
                    Registration is open until slots are filled.
                </p>
            </div>
            <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
          </div>
        </div>

        <div class="flex-1 min-w-0 bg-site-card/40 backdrop-blur-xl border border-site-border p-8 md:p-16 rounded-[40px] shadow-2xl shadow-black/5">
            <div class="mb-12">
                <h3 class="text-4xl md:text-7xl font-black text-site-text italic uppercase tracking-tighter leading-[0.8]">
                    Student <br /> Registration
                </h3>
                <div class="w-20 md:w-24 h-2 bg-primary mt-8 rounded-full"></div>
            </div>

            <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6 md:gap-8 w-full">
                <input type="hidden" name="access_key" value="3e0eb43a-715e-4a1f-ab43-6b729196b441">
                <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                <input type="hidden" name="subject" value="New Student Application - PBSI">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Full Name</label>
                        <input type="text" name="name" required placeholder="Juan Dela Cruz" class="w-full bg-site-bg/60 border border-site-border rounded-2xl px-6 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:opacity-20" />
                    </div>
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Email Address</label>
                        <input type="email" name="email" required placeholder="juan@email.com" class="w-full bg-site-bg/60 border border-site-border rounded-2xl px-6 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:opacity-20" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Home Address</label>
                        <input type="text" name="address" required placeholder="Street, Barangay, City" class="w-full bg-site-bg/60 border border-site-border rounded-2xl px-6 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:opacity-20" />
                    </div>
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Mobile Number</label>
                        <input type="tel" name="phone_number" required placeholder="+63 900 000 0000" class="w-full bg-site-bg/60 border border-site-border rounded-2xl px-6 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:opacity-20" />
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 w-full">
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Age</label>
                        <input type="number" name="age" required placeholder="18" class="w-full bg-site-bg/60 border border-site-border rounded-2xl px-6 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:opacity-20" />
                    </div>
                    <div class="flex flex-col gap-3">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Sex</label>
                        <div class="relative w-full">
                            <select name="sex" required class="w-full bg-site-bg/60 border border-site-border rounded-2xl pl-6 pr-12 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none appearance-none cursor-pointer transition-all">
                                <option value="" disabled selected>Select...</option>
                                <option value="male">Male</option>
                                <option value="female">Female</option>
                            </select>
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-primary">
                                <ChevronDown size={20} />
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-col gap-3 sm:col-span-2 md:col-span-1">
                        <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Civil Status</label>
                        <div class="relative w-full">
                            <select name="civil-status" required class="w-full bg-site-bg/60 border border-site-border rounded-2xl pl-6 pr-12 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none appearance-none cursor-pointer transition-all">
                                <option value="" disabled selected>Select...</option>
                                <option value="single">Single</option>
                                <option value="married">Married</option>
                                <option value="widowed">Widowed</option>
                                <option value="separated">Separated</option>
                            </select>
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-primary">
                                <ChevronDown size={20} />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-3 w-full">
                    <label class="text-[11px] font-black uppercase tracking-[0.2em] text-primary ml-1">Program of Interest</label>
                    <div class="relative w-full">
                        <select name="program" required class="w-full bg-site-bg/60 border border-site-border rounded-2xl pl-6 pr-12 py-4 md:py-5 text-site-text font-bold focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none appearance-none cursor-pointer transition-all">
                            <option value="" disabled selected>Select a program...</option>
                            {allPrograms.map((prog) => (
                                <option value={prog.data.title}>{prog.data.title}</option>
                            ))}
                        </select>
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-primary">
                            <ChevronDown size={20} />
                        </div>
                    </div>
                </div>

                <div class="pt-6 flex justify-center w-full">
                    <button type="submit" class="w-full md:w-auto bg-primary text-white px-10 md:px-14 py-5 md:py-6 rounded-2xl font-black text-lg md:text-xl flex items-center justify-center gap-4 hover:shadow-[0_20px_60px_rgba(var(--primary-rgb),0.5)] transition-all hover:-translate-y-1 active:scale-95 group uppercase italic tracking-tighter shadow-xl shadow-primary/20">
                        Submit Application
                        <ArrowRight size={24} className="group-hover:translate-x-2 transition-transform" />
                    </button>
                </div>
            </form>
        </div>

      </div>
    </div>
  </main>
</Layout>

<style>
  .text-outline {
    -webkit-text-stroke: 1.5px currentColor;
  }
  @media (min-width: 768px) {
    .text-outline {
      -webkit-text-stroke: 2px currentColor;
    }
  }
  .text-outline {
    color: transparent;
  }
  
  select {
    background-image: none;
  }

  option {
    background-color: #ffffff;
    color: #0f172a;
    font-weight: 600;
  }
</style>